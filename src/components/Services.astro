---
const services = [
  {
    title: 'DESARROLLO WEB',
    desc: 'Sitios web responsivos y de alto rendimiento construidos con frameworks modernos. Desde landing pages hasta aplicaciones web complejas.',
    features: ['Laravel, Spring Boot & Node.js', 'React, Vue.js & Alpine.js', 'APIs REST escalables'],
    gradId: 'gs1',
    gradColors: ['#00E5FF', '#00FFA3'],
  },
  {
    title: 'SOLUCIONES MÓVILES',
    desc: 'Aplicaciones móviles nativas y multiplataforma para iOS y Android. Especializándome en Flutter y React Native.',
    features: ['Flutter & React Native', 'Integración con APIs', 'Android Studio & Xcode'],
    gradId: 'gs2',
    gradColors: ['#6C63FF', '#00E5FF'],
  },
  {
    title: 'BASES DE DATOS & BACKEND',
    desc: 'Diseño e implementación de bases de datos robustas y APIs REST escalables con las mejores prácticas de la industria.',
    features: ['PostgreSQL, MySQL & MongoDB', 'APIs REST con autenticación', 'Optimización de consultas'],
    gradId: 'gs3',
    gradColors: ['#00FFA3', '#00E5FF'],
  },
  {
    title: 'DEVOPS & CLOUD',
    desc: 'Deploy y administración de aplicaciones en la nube con Docker, Railway, AWS y configuración de CI/CD.',
    features: ['Railway, AWS & Supabase', 'Docker & Contenedores', 'CI/CD & GitHub Actions'],
    gradId: 'gs4',
    gradColors: ['#FF6B6B', '#6C63FF'],
  },
];
---

<section id="services" class="services reveal-section">
  <div class="container">
    <h2 class="section-title">SERVICIOS FREELANCE</h2>
    <p class="section-subtitle">
      Soluciones de software de vanguardia, adaptadas para tu negocio.
    </p>

    <div class="grid">
      {services.map(({ title, desc, features, gradId, gradColors }) => (
        <div class="glass-card service-card">
          <div class="icon" aria-hidden="true">
            <svg width="60" height="60" viewBox="0 0 60 60" fill="none">
              <circle cx="30" cy="30" r="28" stroke={`url(#${gradId})`} stroke-width="1.5"/>
              <circle cx="30" cy="30" r="8"  fill={`url(#${gradId})`} opacity="0.7"/>
              <defs>
                <linearGradient id={gradId} x1="0" y1="0" x2="60" y2="60">
                  <stop offset="0%"   stop-color={gradColors[0]}/>
                  <stop offset="100%" stop-color={gradColors[1]}/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <h3>{title}</h3>
          <p class="desc">{desc}</p>
          <ul>
            {features.map((f) => <li>{f}</li>)}
          </ul>
          <a href="#contact" class="link">Saber Más →</a>
        </div>
      ))}
    </div>

    <div class="cta">
      <a href="#contact" class="btn btn-large">
        INICIAR UN PROYECTO →<span class="btn-glow"></span>
      </a>
      <p>¿Listo para innovar? Discutamos tu próximo proyecto breakthrough.</p>
    </div>
  </div>
</section>

<style>
  .services { background: rgba(0, 0, 0, 0.2); }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .service-card {
    padding: 2rem;
    transition: all var(--ease);
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--grad-main);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--ease);
    border-radius: 24px 24px 0 0;
  }
  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover {
    transform: translateY(-8px);
    border-color: rgba(0, 229, 255, 0.3);
    box-shadow: 0 16px 50px rgba(0, 229, 255, 0.12);
  }

  .icon { margin-bottom: 1.2rem; }

  h3 {
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 0.9rem;
  }

  .desc {
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
    font-size: 0.87rem;
  }

  ul {
    list-style: none;
    margin-bottom: 1.2rem;
  }
  li {
    color: var(--text-muted);
    padding: 0.35rem 0 0.35rem 1.3rem;
    position: relative;
    font-size: 0.84rem;
  }
  li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--c-cyan);
  }

  .link {
    color: var(--c-cyan);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.87rem;
    display: inline-block;
    transition: all var(--ease);
  }
  .link:hover { transform: translateX(5px); color: var(--c-green); }

  .cta {
    text-align: center;
    margin-top: 4rem;
  }
  .cta p {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 1200px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
