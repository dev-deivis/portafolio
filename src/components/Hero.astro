---
const stack = 'Laravel • Spring Boot • React • Flutter • PostgreSQL • MySQL • Node.js • APIs REST • Docker • AWS';
---

<section id="home" class="hero">
  <div class="hero-content">
    <p class="eyebrow">Hola, soy</p>

    <h1 class="hero-title">
      Desarrollador Full Stack<br />
      &amp; Freelancer
    </h1>

    <p class="hero-name">David Almaraz — Software Developer</p>

    <p class="hero-stack">{stack}</p>

    <div class="hero-btns">
      <a href="#projects" class="btn btn-primary">
        Ver Proyectos<span class="btn-glow"></span>
      </a>
      <a href="#contact" class="btn btn-secondary">
        Contratar<span class="btn-glow"></span>
      </a>
    </div>

    <div class="scroll-hint">
      <span>Scroll para explorar</span>
      <div class="arrow">↓</div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 4rem 4rem;
  }

  .hero-content {
    text-align: center;
    max-width: 900px;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 1rem;
    letter-spacing: 0.2em;
    color: var(--c-green);
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero-title {
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: #ffffff;
    text-shadow:
      0 2px 20px rgba(0,0,0,0.6),
      0 0 60px rgba(255,255,255,0.08);
    opacity: 0;
    animation: fadeUp 0.8s ease 0.4s forwards;
  }

  .hero-name {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    background: linear-gradient(135deg, var(--c-purple), var(--c-cyan), var(--c-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.6s forwards;
  }

  .hero-stack {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 3rem;
    line-height: 1.8;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.8s forwards;
  }

  .hero-btns {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 4rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 1s forwards;
  }

  .scroll-hint {
    opacity: 0;
    animation: fadeUp 0.8s ease 1.2s forwards;
  }
  .scroll-hint span {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.7rem;
  }
  .arrow {
    font-size: 1.8rem;
    animation: bounce 2s infinite;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  @media (max-width: 600px) {
    .hero { padding: 90px 1.5rem 3rem; }
    .hero-btns { flex-direction: column; align-items: center; }
  }
</style>
