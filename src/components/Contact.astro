<section id="contact" class="contact reveal-section">
  <div class="container">
    <h2 class="section-title gradient-text">Construyamos algo juntos</h2>
    <p class="section-subtitle">
      ¿Listo para innovar? Discutamos tu próximo proyecto. Estoy listo para colaborar.
    </p>

    <div class="grid">

      <!-- Formulario -->
      <div class="glass-card form-wrap">
        <form id="contact-form" action="https://formspree.io/f/xwvpjlzj" method="POST" novalidate>
          <div class="field">
            <input type="text"  id="c-name"    name="name"    class="input" placeholder=" " required />
            <label for="c-name">Tu Nombre</label>
          </div>
          <div class="field">
            <input type="email" id="c-email"   name="email"   class="input" placeholder=" " required />
            <label for="c-email">Correo Electrónico</label>
          </div>
          <div class="field">
            <input type="text"  id="c-subject" name="subject" class="input" placeholder=" " required />
            <label for="c-subject">Asunto</label>
          </div>
          <div class="field">
            <textarea id="c-msg" name="message" rows="5" class="input" placeholder=" " required></textarea>
            <label for="c-msg" class="ta-label">Mensaje</label>
          </div>
          <button type="submit" class="btn btn-primary">
            Enviar Mensaje<span class="btn-glow"></span>
          </button>
        </form>

        <div id="form-success" class="success hidden">
          <div class="success-icon">✓</div>
          <h3>¡Mensaje Enviado!</h3>
          <p>Gracias por contactar. Te responderé en menos de 24 horas.</p>
        </div>
      </div>

      <!-- Redes sociales -->
      <div class="glass-card info-wrap">
        <h3>Conecta conmigo</h3>
        <ul class="socials">
          {socials.map(({ label, href, icon, isEmail }) => (
            <li>
              <a
                href={href}
                target={isEmail ? undefined : '_blank'}
                rel={isEmail ? undefined : 'noopener noreferrer'}
                class="social-link"
              >
                {icon ? (
                  <svg width="26" height="26" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
                    <path d={icon}/>
                  </svg>
                ) : (
                  <svg width="26" height="26" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M4 8l12 8 12-8M4 24h24V8H4z"/>
                  </svg>
                )}
                <span>{label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <footer>
    <p>© 2025 David Almaraz · Desarrollador Freelance · Todos los derechos reservados.</p>
  </footer>
</section>

<style>
  .contact { background: rgba(0, 0, 0, 0.1); }

  .grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    margin-top: 3rem;
  }

  /* Formulario */
  .form-wrap { padding: 2.5rem; }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .field { position: relative; }

  .input {
    width: 100%;
    padding: 1rem 1.3rem;
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid transparent;
    border-radius: 14px;
    color: var(--text);
    font-size: 1rem;
    font-family: var(--font);
    transition: all var(--ease);
  }
  .input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--c-cyan);
  }

  label {
    position: absolute;
    left: 1.3rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
    transition: all var(--ease);
    background: transparent;
    padding: 0 0.3rem;
    font-size: 0.95rem;
  }
  .ta-label { top: 1rem; transform: none; }

  .input:focus + label,
  .input:not(:placeholder-shown) + label {
    top: -0.55rem;
    font-size: 0.78rem;
    color: var(--c-cyan);
    background: var(--bg);
    transform: none;
  }
  /* textarea label fix */
  .input:focus + .ta-label,
  .input:not(:placeholder-shown) + .ta-label {
    top: -0.55rem;
    transform: none;
  }

  textarea.input { resize: vertical; min-height: 120px; }

  /* Success */
  .success {
    text-align: center;
    padding: 3rem 2rem;
    background: rgba(0, 255, 163, 0.07);
    border: 2px solid var(--c-green);
    border-radius: 20px;
  }
  .success-icon {
    width: 68px; height: 68px;
    background: var(--c-green);
    color: var(--bg);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.4rem;
    margin: 0 auto 1.2rem;
    animation: popIn 0.6s ease;
  }
  @keyframes popIn {
    0%   { transform: scale(0); }
    60%  { transform: scale(1.2); }
    100% { transform: scale(1); }
  }
  .success h3 { color: var(--c-green); margin-bottom: 0.5rem; }
  .success p  { color: var(--text-muted); }

  /* Social links */
  .info-wrap { padding: 2.5rem; }
  .info-wrap h3 { font-size: 1.3rem; margin-bottom: 1.5rem; }

  .socials { list-style: none; display: flex; flex-direction: column; gap: 1rem; }

  .social-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all var(--ease);
  }
  .social-link svg { color: var(--c-cyan); flex-shrink: 0; }
  .social-link:hover {
    transform: translateX(8px);
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(0, 229, 255, 0.3);
  }

  /* Footer */
  footer {
    text-align: center;
    margin-top: 5rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const res = await fetch(form.action, {
      method:  'POST',
      body:    new FormData(form),
      headers: { Accept: 'application/json' },
    });
    if (res.ok) {
      form.classList.add('hidden');
      success.classList.remove('hidden');
    }
  });
</script>
