---
const frontendBars = [
  { label: 'VUE.JS',       pct: 85 },
  { label: 'TYPESCRIPT',   pct: 80 },
  { label: 'CSS3 / SCSS',  pct: 85 },
];

const dbNodes = [
  { label: 'POSTGRESQL: 90%', color: '#336791' },
  { label: 'REDIS: 80%',      color: '#DC352F' },
  { label: 'MONGODB: 85%',    color: '#47A248' },
  { label: 'ELASTICSEARCH: 75%', color: '#00E5FF' },
];

const pipeSteps = [
  'DOCKER / KUBERNETES: 85%',
  'AWS / AZURE: 80%',
  'CI/CD (GITHUB ACTIONS): 80%',
  'LINUX / BASH: 85%',
];
---

<section id="skills" class="skills reveal-section">
  <div class="container">
    <h2 class="section-title">Panorama de Habilidades</h2>

    <div class="grid">

      <!-- Frontend -->
      <div class="glass-card skill-card">
        <h3 class="cat">DESARROLLO FRONTEND</h3>
        <div class="circle-wrap">
          <div class="circle">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="2" fill="#00E5FF"/>
              <ellipse cx="12" cy="12" rx="9" ry="3.5" stroke="#00E5FF" stroke-width="1.5" fill="none"/>
              <ellipse cx="12" cy="12" rx="9" ry="3.5" stroke="#00E5FF" stroke-width="1.5" fill="none" transform="rotate(60 12 12)"/>
              <ellipse cx="12" cy="12" rx="9" ry="3.5" stroke="#00E5FF" stroke-width="1.5" fill="none" transform="rotate(120 12 12)"/>
            </svg>
            <span class="circle-label">REACT: 85%</span>
          </div>
        </div>
        <div class="bars">
          {frontendBars.map(({ label, pct }) => (
            <div class="bar-row">
              <span>{label}: {pct}%</span>
              <div class="bar-track">
                <div class="bar-fill" style={`--w:${pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Backend -->
      <div class="glass-card skill-card">
        <h3 class="cat">SISTEMAS BACKEND</h3>
        <div class="bubbles">
          <div class="bubble-main">Node.js: 90%</div>
          <div class="bubble-sec">PYTHON (DJANGO/FLASK): 85%</div>
          <div class="bubble-sec delay-1">JAVA (SPRING): 80%</div>
          <div class="bubble-sec delay-2">LARAVEL (PHP): 90%</div>
        </div>
      </div>

      <!-- Bases de datos -->
      <div class="glass-card skill-card">
        <h3 class="cat">BASES DE DATOS</h3>
        <div class="db-grid">
          {dbNodes.map(({ label, color }) => (
            <div class="db-node">
              <div class="db-dot" style={`--c:${color}`}></div>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- DevOps -->
      <div class="glass-card skill-card">
        <h3 class="cat">HERRAMIENTAS &amp; DEVOPS</h3>
        <div class="pipeline">
          {pipeSteps.map((step, i) => (
            <>
              <div class="pipe-step">{step}</div>
              {i < pipeSteps.length - 1 && <div class="pipe-arrow">↓</div>}
            </>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .skills { background: rgba(0, 0, 0, 0.15); }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .skill-card {
    padding: 1.8rem;
    transition: all var(--ease);
  }
  .skill-card:hover {
    transform: translateY(-8px);
    border-color: rgba(0, 229, 255, 0.3);
    box-shadow: 0 16px 50px rgba(0, 229, 255, 0.12);
  }

  .cat {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.2rem;
    text-transform: uppercase;
    font-family: var(--mono);
  }

  /* Frontend circle */
  .circle-wrap {
    display: flex;
    justify-content: center;
    margin: 1.2rem 0;
  }
  .circle {
    width: 115px;
    height: 115px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(108, 99, 255, 0.15), transparent);
    border: 2px solid var(--c-purple);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    animation: circPulse 3s infinite;
  }
  @keyframes circPulse {
    0%, 100% { box-shadow: 0 0 16px rgba(108, 99, 255, 0.35); }
    50%       { box-shadow: 0 0 30px rgba(108, 99, 255, 0.65); }
  }
  .circle-label {
    font-size: 0.68rem;
    font-weight: 700;
    font-family: var(--mono);
    margin-top: 4px;
  }

  /* Barras */
  .bars {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-top: 1rem;
  }
  .bar-row span {
    display: block;
    font-size: 0.68rem;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 0.2rem;
    font-family: var(--mono);
  }
  .bar-track {
    height: 5px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 10px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    width: var(--w, 0%);
    background: var(--grad-main);
    border-radius: 10px;
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.4);
  }

  /* Burbujas backend */
  .bubbles {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-top: 1.2rem;
  }
  .bubble-main {
    background: rgba(0, 229, 255, 0.1);
    border: 2px solid var(--c-cyan);
    border-radius: 30px;
    padding: 0.7rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-align: center;
    box-shadow: 0 0 14px rgba(0, 229, 255, 0.18);
    animation: float 3s ease-in-out infinite;
    font-family: var(--mono);
  }
  .bubble-sec {
    background: rgba(108, 99, 255, 0.1);
    border: 2px solid var(--c-purple);
    border-radius: 30px;
    padding: 0.6rem 0.9rem;
    font-size: 0.68rem;
    font-weight: 600;
    text-align: center;
    animation: float 3s ease-in-out infinite;
    font-family: var(--mono);
  }
  .delay-1 { animation-delay: 0.5s; }
  .delay-2 { animation-delay: 1s; }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }

  /* DB grid */
  .db-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.2rem;
  }
  .db-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-align: center;
  }
  .db-dot {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--c) 18%, transparent);
    border: 2px solid var(--c);
    animation: dbPulse 2.5s ease-in-out infinite;
  }
  @keyframes dbPulse {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.1); }
  }
  .db-node span {
    font-size: 0.62rem;
    color: var(--text-muted);
    font-weight: 600;
    font-family: var(--mono);
  }

  /* Pipeline */
  .pipeline {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 1rem;
  }
  .pipe-step {
    background: rgba(0, 229, 255, 0.07);
    border: 1px solid rgba(0, 229, 255, 0.2);
    border-radius: 20px;
    padding: 0.6rem 0.9rem;
    font-size: 0.65rem;
    text-align: center;
    transition: all var(--ease);
    font-family: var(--mono);
  }
  .pipe-step:hover {
    background: rgba(0, 229, 255, 0.14);
    transform: translateX(6px);
  }
  .pipe-arrow {
    text-align: center;
    color: var(--c-cyan);
    font-size: 1rem;
    animation: arrowDrop 1.5s infinite;
  }
  @keyframes arrowDrop {
    0%, 100% { opacity: 0.4; transform: translateY(0); }
    50%       { opacity: 1;   transform: translateY(3px); }
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
